{
  "name": "wechat-agent-bridge",
  "version": "0.1.0",
  "description": "Bridge personal WeChat iLink to OpenCode AI coding assistant",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop wechat-agent-bridge",
    "pm2:restart": "pm2 restart wechat-agent-bridge",
    "pm2:logs": "pm2 logs wechat-agent-bridge",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.16.2",
    "@pinixai/weixin-bot": "^1.0.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pm2": "^5.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
