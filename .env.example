# OpenCode server configuration
OPENCODE_HOST=127.0.0.1
OPENCODE_PORT=4096

# WeChat iLink session storage
WECHAT_DATA_DIR=./data/wechat

# Feishu (Lark) bot credentials
# Create an app at https://open.feishu.cn/app and get these from "Credentials & Basic Info"
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Session store persistence
SESSION_STORE_PATH=./data/sessions.json

# OpenCode model (optional, uses default if not set)
# OPENCODE_MODEL=anthropic/claude-sonnet-4-20250514

# Logging
LOG_LEVEL=info
